+import io
+from PIL import Image, UnidentifiedImageError
+import pillow_heif
+import fitz  # PyMuPDF
+
+# HEIC/HEIF 플러그인 등록
+pillow_heif.register_heif_opener()
+
+
+def _heic_bytes_to_pil(file_bytes: bytes) -> Image.Image:
+    """
+    HEIC/HEIF를 안정적으로 PIL Image로 변환
+    - 1차: Pillow(Image.open) 시도
+    - 2차: 실패 시 pillow_heif.read_heif로 직접 디코딩 fallback
+    """
+    bio = io.BytesIO(file_bytes)
+    try:
+        img = Image.open(bio)
+        img.load()
+        return img
+    except (UnidentifiedImageError, OSError):
+        heif = pillow_heif.read_heif(file_bytes)
+        return Image.frombytes(heif.mode, heif.size, heif.data, "raw")
+
+
+def normalize_upload(file_bytes: bytes, filename: str) -> tuple[bytes, str]:
+    ext = filename.rsplit(".", 1)[-1].lower()
+    try:
+        if ext == "pdf":
+            # PDF -> 첫 페이지를 PNG로 변환
+            doc = fitz.open(stream=file_bytes, filetype="pdf")
+            try:
+                page = doc.load_page(0)
+                pix = page.get_pixmap(dpi=150)
+                img = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
+            finally:
+                doc.close()
+
+            img_byte_arr = io.BytesIO()
+            img.save(img_byte_arr, format="PNG")
+            return img_byte_arr.getvalue(), filename.rsplit(".", 1)[0] + ".png"
+
+        if ext in {"heic", "heif"}:
+            # HEIC/HEIF -> PNG
+            image = _heic_bytes_to_pil(file_bytes)
+            if image.mode != "RGB":
+                image = image.convert("RGB")
+            img_byte_arr = io.BytesIO()
+            image.save(img_byte_arr, format="PNG")
+            return img_byte_arr.getvalue(), filename.rsplit(".", 1)[0] + ".png"
+
+        # 일반 PNG, JPG는 원본 그대로 통과
+        return file_bytes, filename
+
+    except Exception as e:
+        raise Exception(f"파일 변환 실패: {str(e)}")
